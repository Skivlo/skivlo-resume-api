const { PLANS } = require("../constants/appConstants");

const checkPremiumAccess = async (req, res, next) => {

    try {

        if (!req.user) {

            return res.status(401).json({

                success: false,

                message: "Login required"

            });

        }

        if (req.user.plan !== PLANS.BOOST) {

            return res.status(403).json({

                success: false,

                message: "Boost Resume required"

            });

        }

        next();

    } catch (error) {

        next(error);

    }

};

module.exports = {

    checkPremiumAccess

};
